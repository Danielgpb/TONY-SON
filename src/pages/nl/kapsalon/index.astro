---
import Layout from '../../../layouts/Layout.astro';

const seoTitle = "Kapsalon Brussel – Tony&Son | Kleuringen, Verzorging & Kapsels";
const seoDesc = "Kapsalon in Brussel: kleuringen, balayage, highlights, föhn, stijlen, keratine, extensions, permanenten, kinderkapsels. Tony&Son sinds 1970.";

const categorySchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kapsalon",
  "provider": { "@type": "HairSalon", "name": "Tony&Son", "@id": "https://tonyandson.be/#business", "telephone": "02 230 55 37", "address": { "@type": "PostalAddress", "streetAddress": "Rue Bonneels 27", "addressLocality": "Sint-Joost-ten-Node", "postalCode": "1210", "addressCountry": "BE" } },
  "areaServed": "Brussel"
};
---

<Layout title={seoTitle} locale="nl" page="coiffure" description={seoDesc}>
  <section class="titlebar" style="background-image: url('/images/titlebar-bg.jpg')">
    <div class="titlebar-overlay"></div>
    <div class="container">
      <h1>Kapsalon in Brussel — Vrouwen, mannen & kinderen bij Tony&Son</h1>
      <p class="titlebar-sub">Kapsalon in Sint-Joost-ten-Node sinds 1970</p>
    </div>
  </section>

  <section class="category-intro">
    <div class="container">
      <p class="intro-text">Bij <a href="/nl/">Tony&Son</a>, kapsalon in Sint-Joost-ten-Node nabij de Schumanwijk, biedt de familie Campisi sinds 1970 een volledig aanbod haardiensten. Kleuringen, verzorgingen, kapsels en geavanceerde technieken — voor vrouwen, mannen en kinderen. Bereikbaar vanuit Schaarbeek, Etterbeek, de Europese wijk en heel Brussel.</p>
    </div>
  </section>

  <section class="services-editorial">
    <div class="container">
      <div class="service-editorial-block">
        <h2>Haarkleuring op maat</h2>
        <p>Onze <a href="/nl/services/haarkleuring-brussel/">haarkleuringen</a> dekken het volledige spectrum: volledige kleuring, uitgroei bijwerken, ton-sur-ton en plantaardig. We beginnen altijd met een eerlijke beoordeling — en kleurcorrectie van andere salons is een van onze specialiteiten. Vanaf 40 €.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Balayage en natuurlijke highlights</h2>
        <p>Voor een "door de zon gekust" effect creëert onze <a href="/nl/services/balayage-brussel/">handgeschilderde balayage</a> reflecties die goed verouderen — discrete uitgroei, bijwerken om de 3-4 maanden. Vanaf 35 €.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Gestructureerde highlights</h2>
        <p>Preciezer dan balayage, onze <a href="/nl/services/highlights-brussel/">highlights</a> bieden opvallende contrasten — folie voor een regelmatig resultaat, kapje voor fijne reflecties, of vrije hand voor een losser effect.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Verloopkleuring</h2>
        <p>Ombré, sombré of dip-dye: onze <a href="/nl/services/ombre-kleuring-brussel/">verloopkleuring</a> speelt op drie intensiteiten. Uitgroei is deel van de stijl — onderhoud om de 3-4 maanden. Vanaf 40 €.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Express föhn</h2>
        <p>Glad, volume of wavy — onze <a href="/nl/services/fohn-brussel/">professionele föhn</a> bevat shampoo en hittebescherming. 30-45 minuten voor een resultaat dat 2-4 dagen houdt. Vanaf 30 €.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Braziliaans stijlen, tanine en botox</h2>
        <p>Onze <a href="/nl/services/haar-stijlen-brussel/">stijlservice</a> biedt drie opties voor drie behoeften. EU-conforme producten — we tonen u het productblad. Vanaf 150 €.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Keratinebehandeling — verzorging, geen stijlen</h2>
        <p>Onze <a href="/nl/services/keratine-behandeling-brussel/">keratinebehandeling</a> is een diepe herstelling die het natuurlijke eiwit herbouwt, pluis vermindert en glans herstelt. Effect 3-4 maanden.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Natuurlijke haarextensions</h2>
        <p>Keratine, micro-ringen, tape-in of clips — onze <a href="/nl/services/hair-extensions-brussel/">Remy haarextensions</a> passen bij vier situaties. Consultatie verplicht. Vanaf 500 €.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Moderne permanenten</h2>
        <p>Spiraal, body wave of gedeeltelijk — onze <a href="/nl/services/permanent-brussel/">moderne permanenten</a> hebben niets te maken met de jaren 80. Zachte formules, gecontroleerde resultaten. 3-6 maanden.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Haar hergroei behandelingen</h2>
        <p>Onze <a href="/nl/services/haar-hergroei-brussel/">haar hergroei behandelingen</a> combineren anti-haaruitval, hoofdhuidstimulatie en versterkingsprotocollen. Eerlijke diagnose, geen valse beloften.</p>
      </div>
      <div class="service-editorial-block">
        <h2>Kinderkapsels — geduld gegarandeerd</h2>
        <p>Onze stylisten passen zich aan het tempo van het kind aan — pauze indien nodig, op schoot, geen druk. Jongens en meisjes, zelfde prijs voor een <a href="/nl/services/kinderkapsels-brussel/">kinderkapsel</a>. Vanaf 25 €.</p>
      </div>
    </div>
  </section>

  <section class="category-cta">
    <div class="container" style="text-align: center;">
      <h2>Maak een afspraak bij Tony&Son</h2>
      <p>Kapsalon in Sint-Joost-ten-Node, Brussel — Open dinsdag tot zaterdag</p>
      <div class="cta-buttons">
        <a href="tel:+3222305537" class="btn">02 230 55 37</a>
        <a href="https://widget.treatwell.be/fr/salon/tony-and-son/" target="_blank" rel="noopener" class="btn btn-dark">Online boeken</a>
      </div>
    </div>
  </section>

  <section class="category-map">
    <div class="container">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2518.5!2d4.3779093!3d50.8489674!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c3c3618601861f%3A0x573e8530643fa9d3!2sTony%26Son+%E2%9C%82!5e0!3m2!1snl!2sbe!4v1710000000000" width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Tony&Son Kapsalon Brussel"></iframe>
    </div>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(categorySchema)} />
</Layout>

<style>
  .titlebar { position: relative; background-size: cover; background-position: center; padding: 160px 0 60px; text-align: center; }
  .titlebar-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); }
  .titlebar h1 { position: relative; z-index: 2; font-size: 36px; color: var(--color-white); }
  .titlebar-sub { position: relative; z-index: 2; color: var(--color-gold); font-family: var(--font-display); font-style: italic; font-size: 18px; margin-top: 10px; text-transform: none; }
  .category-intro { padding: 60px 0 40px; }
  .intro-text { max-width: 900px; margin: 0 auto; font-size: 18px; line-height: 1.8; color: var(--color-text); text-align: center; }
  .intro-text a { color: var(--color-gold); font-weight: 600; }
  .services-editorial { padding: 40px 0 80px; }
  .service-editorial-block { padding: 35px 0; border-bottom: 1px solid var(--color-border); }
  .service-editorial-block:last-child { border-bottom: none; }
  .service-editorial-block h2 { font-size: 24px; margin-bottom: 15px; }
  .service-editorial-block p { font-size: 16px; line-height: 1.8; color: var(--color-text); }
  .service-editorial-block p a { color: var(--color-gold); font-weight: 500; }
  .category-cta { padding: 80px 0; background: var(--color-black); }
  .category-cta h2 { color: var(--color-white); margin-bottom: 10px; }
  .category-cta p { color: var(--color-text-light); font-size: 16px; margin-bottom: 30px; text-transform: none; }
  .cta-buttons { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; }
  .category-map { padding: 0; }
  .category-map iframe { display: block; }
  @media (max-width: 768px) { .titlebar { padding: 120px 0 40px; } .titlebar h1 { font-size: 24px; } .cta-buttons { flex-direction: column; align-items: center; } }
</style>
