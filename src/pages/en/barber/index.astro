---
import Layout from '../../../layouts/Layout.astro';

const seoTitle = "Barber Brussels – Beard Trim & Men's Grooming | Tony&Son";
const seoDesc = "Barber in Brussels: beard trim, traditional shaving, fades, waxing, kids haircuts. Tony&Son barber shop in Saint-Josse-ten-Noode since 1970.";

const categorySchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Barber",
  "provider": {
    "@type": "HairSalon",
    "name": "Tony&Son",
    "@id": "https://tonyandson.be/#business",
    "telephone": "02 230 55 37",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rue Bonneels 27",
      "addressLocality": "Saint-Josse-ten-Noode",
      "postalCode": "1210",
      "addressCountry": "BE"
    }
  },
  "areaServed": "Brussels"
};
---

<Layout title={seoTitle} locale="en" page="barbier" description={seoDesc}>
  <section class="titlebar" style="background-image: url('/images/titlebar-bg.jpg')">
    <div class="titlebar-overlay"></div>
    <div class="container">
      <h1>Barber in Brussels — Beard trim and men's grooming at Tony&Son</h1>
      <p class="titlebar-sub">Barber shop in Saint-Josse-ten-Noode since 1970</p>
    </div>
  </section>

  <section class="category-intro">
    <div class="container">
      <div class="intro-grid">
        <p class="intro-text">Tony&Son, your <a href="/en/">barber in Saint-Josse-ten-Noode</a> near the Schuman quarter in Brussels. Our experienced barbers have mastered the art of beard trimming, traditional shaving and men's grooming since 1970. All hair textures — European, North African, Afro, Asian. Service in French and English. Accessible from Schaerbeek, Etterbeek, the European quarter and all of Brussels.</p>
        <img src="/images/barbier-1.jpg" alt="Barber Tony&Son Brussels — beard trim and shaving" class="intro-img" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="services-editorial">
    <div class="container">

      <div class="service-editorial-block">
        <h2>Beard trim and traditional shaving</h2>
        <p>Our <a href="/en/services/beard-trim-brussels/">beard trim</a> always starts with a conversation — face shape, growth pattern, what you want. Precision clippers, scissors for finishing, straight razor for the edges. Traditional cutthroat shaving with hot towel available. American fades (skin fade, mid fade, taper) mastered on all textures.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Kids haircuts — patience and care</h2>
        <p>For boys who want their first fade or a cut like dad's, our <a href="/en/services/kids-haircut-brussels/">kids haircut</a> is done gently. Our barbers adapt to the child's pace with patience and kindness. Same price for boys and girls, from €25.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Facial waxing</h2>
        <p>Eyebrows, upper lip, chin — our <a href="/en/services/facial-waxing-brussels/">facial waxing</a> is a quick, warm-wax gesture at €10. Can be combined with a beard trim or haircut in the same session, just mention it when booking.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Men's hair colouring</h2>
        <p>To cover first grey hairs or refresh a dull shade, our <a href="/en/services/hair-coloring-brussels/">hair colouring</a> adapts to men's hair texture — discreet tone-on-tone or full colour. From €40.</p>
      </div>

    </div>
  </section>

  <section class="category-cta">
    <div class="container" style="text-align: center;">
      <h2>Book an appointment at Tony&Son</h2>
      <p>Barber in Saint-Josse-ten-Noode, Brussels — Open Tuesday to Saturday</p>
      <div class="cta-buttons">
        <a href="tel:+3222305537" class="btn">02 230 55 37</a>
        <a href="https://widget.treatwell.be/fr/salon/tony-and-son/" target="_blank" rel="noopener" class="btn btn-dark">Book online</a>
      </div>
    </div>
  </section>

  <section class="category-map">
    <div class="container">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2518.5!2d4.3779093!3d50.8489674!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c3c3618601861f%3A0x573e8530643fa9d3!2sTony%26Son+%E2%9C%82!5e0!3m2!1sen!2sbe!4v1710000000000"
        width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade" title="Tony&Son Barber Brussels"></iframe>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(categorySchema)} />
</Layout>

<style>
  .titlebar { position: relative; background-size: cover; background-position: center; padding: 160px 0 60px; text-align: center; }
  .titlebar-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); }
  .titlebar h1 { position: relative; z-index: 2; font-size: 36px; color: var(--color-white); }
  .titlebar-sub { position: relative; z-index: 2; color: var(--color-gold); font-family: var(--font-display); font-style: italic; font-size: 18px; margin-top: 10px; text-transform: none; }
  .category-intro { padding: 60px 0 40px; }
  .intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
  .intro-text { font-size: 18px; line-height: 1.8; color: var(--color-text); }
  .intro-text a { color: var(--color-gold); font-weight: 600; }
  .intro-img { width: 100%; height: 350px; object-fit: cover; border-radius: 8px; }
  .services-editorial { padding: 40px 0 80px; }
  .service-editorial-block { padding: 35px 0; border-bottom: 1px solid var(--color-border); }
  .service-editorial-block:last-child { border-bottom: none; }
  .service-editorial-block h2 { font-size: 24px; margin-bottom: 15px; }
  .service-editorial-block p { font-size: 16px; line-height: 1.8; color: var(--color-text); }
  .service-editorial-block p a { color: var(--color-gold); font-weight: 500; }
  .category-cta { padding: 80px 0; background: var(--color-black); }
  .category-cta h2 { color: var(--color-white); margin-bottom: 10px; }
  .category-cta p { color: var(--color-text-light); font-size: 16px; margin-bottom: 30px; text-transform: none; }
  .cta-buttons { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; }
  .category-map { padding: 0; }
  .category-map iframe { display: block; }
  @media (max-width: 768px) {
    .titlebar { padding: 120px 0 40px; }
    .titlebar h1 { font-size: 24px; }
    .intro-grid { grid-template-columns: 1fr; }
    .intro-img { height: 250px; }
    .cta-buttons { flex-direction: column; align-items: center; }
  }
</style>
