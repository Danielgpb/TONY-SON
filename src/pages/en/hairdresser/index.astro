---
import Layout from '../../../layouts/Layout.astro';

const seoTitle = "Hairdresser Brussels – Tony&Son Salon | Colouring, Care & Cuts";
const seoDesc = "Hair salon in Brussels: colouring, balayage, highlights, blowouts, straightening, keratin, extensions, perms, kids haircuts. Tony&Son since 1970.";

const categorySchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Hairdresser",
  "provider": {
    "@type": "HairSalon",
    "name": "Tony&Son",
    "@id": "https://tonyandson.be/#business",
    "telephone": "02 230 55 37",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rue Bonneels 27",
      "addressLocality": "Saint-Josse-ten-Noode",
      "postalCode": "1210",
      "addressCountry": "BE"
    }
  },
  "areaServed": "Brussels"
};
---

<Layout title={seoTitle} locale="en" page="coiffure" description={seoDesc}>
  <section class="titlebar" style="background-image: url('/images/titlebar-bg.jpg')">
    <div class="titlebar-overlay"></div>
    <div class="container">
      <h1>Hairdresser in Brussels — Women, Men & Children at Tony&Son</h1>
      <p class="titlebar-sub">Hair salon in Saint-Josse-ten-Noode since 1970</p>
    </div>
  </section>

  <section class="category-intro">
    <div class="container">
      <p class="intro-text">At <a href="/en/">Tony&Son</a>, hair salon in Saint-Josse-ten-Noode near the Schuman quarter, the Campisi family has offered a full range of hair services since 1970. Colouring, treatments, cuts and advanced techniques — for women, men and children. Service in French and English. Accessible from Schaerbeek, Etterbeek, the European quarter and all of Brussels.</p>
    </div>
  </section>

  <section class="services-editorial">
    <div class="container">

      <div class="service-editorial-block">
        <h2>Custom hair colouring</h2>
        <p>Our <a href="/en/services/hair-coloring-brussels/">hair colouring service</a> covers the full spectrum: full colour, root touch-ups, tone-on-tone and plant-based options. We always start with an honest assessment — and colour correction from other salons is one of our specialities. From €40.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Balayage and natural highlights</h2>
        <p>For a sun-kissed effect, our <a href="/en/services/balayage-brussels/">freehand balayage</a> creates reflections that age well — discreet regrowth, touch-up every 3-4 months only. French balayage, babylights, honey or ash. From €35.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Structured highlights</h2>
        <p>More precise than balayage, our <a href="/en/services/highlights-brussels/">highlights</a> offer bold contrasts — foil for a regular result, cap for fine reflections, or freehand for a freer finish. Maintenance every 6-8 weeks.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Gradient colouring</h2>
        <p>Ombré, sombré or dip-dye: our <a href="/en/services/ombre-hair-color-brussels/">gradient colouring</a> plays on three intensities. The common thread? Regrowth is part of the style — touch-up every 3-4 months, the most economical technique. From €40.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Express or event blowout</h2>
        <p>Sleek, volume or wavy — our <a href="/en/services/blowout-brussels/">professional blowout</a> includes shampoo and heat protectant. 30-45 minutes for a result that lasts 2-4 days. From €30.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Brazilian straightening, tanin and botox</h2>
        <p>Our <a href="/en/services/hair-straightening-brussels/">straightening service</a> offers three options for three different needs. EU-compliant products — we show you the data sheet before touching your hair. From €150.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Keratin treatment — repair, not straightening</h2>
        <p>Our <a href="/en/services/keratin-treatment-brussels/">keratin treatment</a> is a deep repair that rebuilds the hair's natural protein, reduces frizz and restores shine. Ideal after colouring or balayage. Effect lasts 3-4 months.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Natural hair extensions</h2>
        <p>Keratin, micro-rings, tape-in or clips — our <a href="/en/services/hair-extensions-brussels/">Remy hair extensions</a> suit four different situations. Consultation is essential: we assess density and hair health before any application. From €500.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Modern perms</h2>
        <p>Spiral, body wave or partial — our <a href="/en/services/perm-brussels/">modern perms</a> are nothing like the 80s. Gentle formulas, controlled results. Body wave for soft undulations is our most requested variation. Result lasts 3-6 months.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Hair regrowth treatments</h2>
        <p>Our <a href="/en/services/hair-regrowth-brussels/">hair regrowth treatments</a> combine anti-hair-loss care, scalp stimulation and strengthening protocols. Every treatment starts with a full assessment to identify the cause. Realistic solutions, no false promises.</p>
      </div>

      <div class="service-editorial-block">
        <h2>Kids haircuts — patience guaranteed</h2>
        <p>Our stylists adapt to the child's pace — breaks if needed, parent's lap, no pressure. Boys and girls, same price for a <a href="/en/services/kids-haircut-brussels/">kids haircut</a>. From €25.</p>
      </div>

    </div>
  </section>

  <section class="category-cta">
    <div class="container" style="text-align: center;">
      <h2>Book an appointment at Tony&Son</h2>
      <p>Hair salon in Saint-Josse-ten-Noode, Brussels — Open Tuesday to Saturday</p>
      <div class="cta-buttons">
        <a href="tel:+3222305537" class="btn">02 230 55 37</a>
        <a href="https://widget.treatwell.be/fr/salon/tony-and-son/" target="_blank" rel="noopener" class="btn btn-dark">Book online</a>
      </div>
    </div>
  </section>

  <section class="category-map">
    <div class="container">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2518.5!2d4.3779093!3d50.8489674!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c3c3618601861f%3A0x573e8530643fa9d3!2sTony%26Son+%E2%9C%82!5e0!3m2!1sen!2sbe!4v1710000000000"
        width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade" title="Tony&Son Hairdresser Brussels"></iframe>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(categorySchema)} />
</Layout>

<style>
  .titlebar { position: relative; background-size: cover; background-position: center; padding: 160px 0 60px; text-align: center; }
  .titlebar-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); }
  .titlebar h1 { position: relative; z-index: 2; font-size: 36px; color: var(--color-white); }
  .titlebar-sub { position: relative; z-index: 2; color: var(--color-gold); font-family: var(--font-display); font-style: italic; font-size: 18px; margin-top: 10px; text-transform: none; }
  .category-intro { padding: 60px 0 40px; }
  .intro-text { max-width: 900px; margin: 0 auto; font-size: 18px; line-height: 1.8; color: var(--color-text); text-align: center; }
  .intro-text a { color: var(--color-gold); font-weight: 600; }
  .services-editorial { padding: 40px 0 80px; }
  .service-editorial-block { padding: 35px 0; border-bottom: 1px solid var(--color-border); }
  .service-editorial-block:last-child { border-bottom: none; }
  .service-editorial-block h2 { font-size: 24px; margin-bottom: 15px; }
  .service-editorial-block p { font-size: 16px; line-height: 1.8; color: var(--color-text); }
  .service-editorial-block p a { color: var(--color-gold); font-weight: 500; }
  .category-cta { padding: 80px 0; background: var(--color-black); }
  .category-cta h2 { color: var(--color-white); margin-bottom: 10px; }
  .category-cta p { color: var(--color-text-light); font-size: 16px; margin-bottom: 30px; text-transform: none; }
  .cta-buttons { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; }
  .category-map { padding: 0; }
  .category-map iframe { display: block; }
  @media (max-width: 768px) {
    .titlebar { padding: 120px 0 40px; }
    .titlebar h1 { font-size: 24px; }
    .cta-buttons { flex-direction: column; align-items: center; }
  }
</style>
