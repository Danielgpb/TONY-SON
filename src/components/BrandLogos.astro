---
import type { Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const tagline = locale === 'nl' ? 'Onze geselecteerde producten' : locale === 'en' ? 'Our selected products' : 'Nos produits sélectionnés';
const title = locale === 'nl' ? 'Onze partnermerken' : locale === 'en' ? 'Our partner brands' : 'Nos marques partenaires';
---

<section class="brands-section">
  <div class="container">
    <h5 class="tagline" style="text-align:center;">{tagline}</h5>
    <h2 class="section-title" style="text-align:center;margin-bottom:60px;">{title}</h2>
    <div class="brands-grid">
      <div class="brand-col">
        <img src="/images/brand-1.png" alt="Produits capillaires professionnels utilisés chez Tony&Son" loading="lazy" />
      </div>
      <div class="brand-col">
        <img src="/images/brand-2.png" alt="Marques partenaires du salon Tony&Son Bruxelles" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .brands-section {
    margin-top: 150px;
    padding: 80px 0 100px;
  }
  .brands-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .brand-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px;
    border-left: 1px solid rgba(209,176,150,0.4);
  }
  .brand-col:first-child {
    border-left: none;
  }
  .brand-col img {
    max-width: 250px;
    height: auto;
    opacity: 0.8;
    transition: all 0.3s ease;
  }
  .brand-col img:hover {
    opacity: 1;
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .brands-section { margin-top: 60px; padding: 60px 0; }
    .brand-col { padding: 30px; }
    .brand-col img { max-width: 180px; }
  }
</style>
