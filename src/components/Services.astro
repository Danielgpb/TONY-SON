---
import type { Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const tagline = "L'Art de la Perfection";
const title = locale === 'nl' ? 'Vertrouwen begint met een perfect kapsel' : locale === 'en' ? 'Confidence starts with a perfect haircut' : 'La confiance commence par une coiffure parfaite';
const text = locale === 'nl' ? "Bij Tony&Son wordt elke knipbeurt met zorg en precisie uitgevoerd om uw ware schoonheid te onthullen. Wij geloven dat elk detail telt om uw stijl te verfijnen en u het vertrouwen te geven om uw beste look te tonen." : locale === 'en' ? "At Tony&Son, every cut is made with care and precision to reveal your true beauty. We believe that every detail counts to enhance your style and give you the confidence to show your best look." : "Chez Tony&Son, chaque coupe est réalisée avec soin et précision pour révéler votre véritable beauté. Nous croyons que chaque détail compte pour sublimer votre style et vous donner la confiance d'afficher votre meilleur look.";
const cta = locale === 'nl' ? 'Boek uw bezoek' : locale === 'en' ? 'Book your visit' : 'Réservez votre visite';
---

<section class="cta-section" style="background-image: url('/images/photo-11.jpeg')">
  <div class="cta-inner">
    <div class="cta-box">
      <h5 class="tagline">{tagline}</h5>
      <h2 class="cta-title">{title}</h2>
      <p class="cta-desc">{text}</p>
      <a href="https://widget.treatwell.be/fr/salon/tony-and-son/" target="_blank" rel="noopener" class="btn btn-white" style="margin-top:40px;">{cta}</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    margin-top: 150px;
    background-size: cover;
    background-position: bottom center;
    position: relative;
    min-height: 700px;
    display: flex;
    align-items: flex-end;
  }
  .cta-inner {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 45% 55%;
  }
  .cta-box {
    background: var(--color-black);
    padding: 80px;
    z-index: 2;
  }
  .cta-title {
    font-size: 36px;
    color: var(--color-white);
    margin-bottom: 25px;
    line-height: 1.3;
  }
  .cta-desc {
    color: var(--color-text-light);
    font-size: 16px;
    line-height: 1.8;
  }

  @media (max-width: 1024px) {
    .cta-section { min-height: 550px; margin-top: 100px; }
    .cta-inner { grid-template-columns: 55% 45%; }
    .cta-box { padding: 60px; }
  }
  @media (max-width: 768px) {
    .cta-section { min-height: 400px; margin-top: 80px; }
    .cta-inner { grid-template-columns: 1fr; }
    .cta-box { padding: 40px 30px; }
    .cta-title { font-size: 28px; }
  }
</style>
