---
import type { Locale } from '../i18n';
import { getAlternateUrls } from '../data/slug-map';

interface Props {
  locale: Locale;
  currentPage?: string;
  pathname?: string;
}

const { locale, currentPage = '', pathname = '' } = Astro.props;

// Use slug-map for correct translated URLs
const currentPath = pathname || Astro.url?.pathname || `/${locale}/`;
const alternateUrls = getAlternateUrls(currentPath);

const languages = [
  { code: 'fr' as Locale, label: 'FR', href: alternateUrls.fr },
  { code: 'en' as Locale, label: 'EN', href: alternateUrls.en },
  { code: 'nl' as Locale, label: 'NL', href: alternateUrls.nl },
];
---

<div class="lang-switcher" role="navigation" aria-label="Language selection">
  {languages.map((lang, i) => (
    <>
      {i > 0 && <span class="lang-sep">|</span>}
      <a
        href={lang.href}
        class:list={['lang-link', { active: locale === lang.code }]}
        hreflang={lang.code}
      >
        {lang.label}
      </a>
    </>
  ))}
</div>

<style>
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }
  .lang-sep {
    color: var(--color-text-light);
    font-size: 0.7rem;
    opacity: 0.5;
  }
  .lang-link {
    font-family: var(--font-accent);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 8px 10px;
    color: var(--color-text);
    transition: var(--transition);
    text-transform: uppercase;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lang-link:hover {
    color: var(--color-heading);
  }
  .lang-link.active {
    color: var(--color-gold);
    font-weight: 700;
  }
</style>
