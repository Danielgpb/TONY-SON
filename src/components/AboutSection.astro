---
import type { Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const tagline = locale === 'nl' ? 'Kapsalon sinds 1970' : locale === 'en' ? 'Hair salon since 1970' : 'Salon de coiffure depuis 1970';
const title = locale === 'nl' ? 'Tony&Son — Sint-Joost-ten-Node' : locale === 'en' ? 'Tony&Son — Saint-Josse-ten-Noode' : 'Tony&Son — Saint-Josse-ten-Noode';
const text = locale === 'nl' ? "Tony&Son is een kapsalon in Sint-Joost-ten-Node, Brussel, opgericht in 1970 door Tony Campisi en overgenomen door zijn zoon Salvatore, opgeleid bij Toni&Guy in Londen. Drie generaties vakmanschap in de wijk Schuman. Knippen, kleuren, balayage, gladmaken, barbier — voor vrouwen, mannen en kinderen. Uw schoonheid, onze traditie." : locale === 'en' ? "Tony&Son is a hair salon in Saint-Josse-ten-Noode, Brussels, founded in 1970 by Tony Campisi and taken over by his son Salvatore, trained at Toni&Guy in London. Three generations of expertise near the Schuman quarter. Cuts, colouring, balayage, smoothing, barbering — for women, men and children. Your beauty, our tradition." : "Tony&Son, salon de coiffure à Saint-Josse-ten-Noode, Bruxelles, fondé en 1970 par Tony Campisi et repris par son fils Salvatore, formé chez Toni&Guy à Londres. Trois générations de savoir-faire près du quartier Schuman. Coupes, colorations, balayage, lissage, barbier — pour femmes, hommes et enfants. Rue Bonneels 27, à deux minutes du métro Schuman.";
const btnText = locale === 'nl' ? 'Over ons' : locale === 'en' ? 'About us' : 'à propos de nous';
---

<section class="welcome">
  <div class="container">
    <div class="welcome-grid">
      <div class="welcome-text">
        <h5 class="tagline">{tagline}</h5>
        <h2 class="welcome-title">{title}</h2>
        <p class="welcome-desc">{text}</p>
        <a href={`/${locale}/about/`} class="btn btn-white">{btnText}</a>
      </div>
      <div class="welcome-images">
        <div class="img-col">
          <img src="/images/photo-7.jpeg" alt="Tony&Son" loading="lazy" />
        </div>
        <div class="img-col">
          <img src="/images/photo-3.jpeg" alt="Tony&Son" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .welcome {
    margin-top: 150px;
  }
  .welcome-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .welcome-text {
    padding-right: 40px;
  }
  .welcome-title {
    font-size: 36px;
    text-transform: uppercase;
    color: var(--color-heading);
    margin-bottom: 25px;
    line-height: 1.3;
  }
  .welcome-desc {
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 35px;
  }
  .welcome-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .welcome-images img {
    width: 100%;
    height: 450px;
    object-fit: cover;
    transition: transform 3.5s cubic-bezier(.17, .05, .13, .85);
  }
  .img-col {
    overflow: hidden;
  }
  .img-col:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 1024px) {
    .welcome { margin-top: 100px; }
    .welcome-text { padding-right: 0; }
    .welcome-images img { height: 350px; }
  }
  @media (max-width: 768px) {
    .welcome { margin-top: 60px; }
    .welcome-grid { grid-template-columns: 1fr; gap: 40px; }
    .welcome-images img { height: 300px; }
    .welcome-desc { font-size: 16px; }
    .img-col:first-child { display: none; }
  }
</style>
