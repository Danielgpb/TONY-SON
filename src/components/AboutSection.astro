---
import type { Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const tagline = locale === 'nl' ? 'Welkom bij Tony&Son' : locale === 'en' ? 'Welcome to Tony&Son' : 'Welcome to Tony&son';
const title = locale === 'nl' ? 'Welkom bij kapsalon Tony&Son' : locale === 'en' ? 'Welcome to Tony&Son hair salon' : 'Bienvenu au salon Tony&Son';
const text = locale === 'nl' ? "Tony&Son is een kapsalon opgericht in 1970 door Tony Campisi en overgenomen door zijn zoon Salvatore, opgeleid aan de Toni&Guy school. De familietraditie en het vakmanschap worden voortgezet om een op maat gemaakte ervaring te bieden, die traditie en creativiteit combineert. In een warme en elegante sfeer telt elk detail. De salon biedt knippen, transformaties en persoonlijk advies, om de unieke schoonheid van elke klant te onthullen. Uw schoonheid, onze traditie." : locale === 'en' ? "Tony&Son is a hair salon founded in 1970 by Tony Campisi and taken over by his son Salvatore, trained at the Toni&Guy school. The family heritage and expertise continue to offer a tailor-made experience, combining tradition and creativity. In a warm and elegant atmosphere, every detail counts. The salon offers cuts, transformations and personalized advice, to reveal the unique beauty of each client. Your beauty, our tradition." : "Tony&Son est un salon de coiffure fondé en 1970 par Tony Campisi et repris par son fils Salvatore, formé à l'école Toni&Guy. L'héritage familial et le savoir-faire se perpétuent pour offrir une expérience sur-mesure, alliant tradition et créativité. Dans une ambiance chaleureuse et élégante, chaque détail compte. Le salon propose des coupes, transformations et conseils personnalisés, pour révéler la beauté unique de chaque client. Votre beauté, notre tradition.";
const btnText = locale === 'nl' ? 'Over ons' : locale === 'en' ? 'About us' : 'à propos de nous';
---

<section class="welcome">
  <div class="container">
    <div class="welcome-grid">
      <div class="welcome-text">
        <h5 class="tagline">{tagline}</h5>
        <h2 class="welcome-title">{title}</h2>
        <p class="welcome-desc">{text}</p>
        <a href={`/${locale}/about/`} class="btn btn-white">{btnText}</a>
      </div>
      <div class="welcome-images">
        <div class="img-col">
          <img src="/images/photo-7.jpeg" alt="Tony&Son" loading="lazy" />
        </div>
        <div class="img-col">
          <img src="/images/photo-3.jpeg" alt="Tony&Son" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .welcome {
    margin-top: 150px;
  }
  .welcome-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .welcome-text {
    padding-right: 40px;
  }
  .welcome-title {
    font-size: 36px;
    text-transform: uppercase;
    color: var(--color-heading);
    margin-bottom: 25px;
    line-height: 1.3;
  }
  .welcome-desc {
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 35px;
  }
  .welcome-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .welcome-images img {
    width: 100%;
    height: 450px;
    object-fit: cover;
    transition: transform 3.5s cubic-bezier(.17, .05, .13, .85);
  }
  .img-col {
    overflow: hidden;
  }
  .img-col:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 1024px) {
    .welcome { margin-top: 100px; }
    .welcome-text { padding-right: 0; }
    .welcome-images img { height: 350px; }
  }
  @media (max-width: 768px) {
    .welcome { margin-top: 60px; }
    .welcome-grid { grid-template-columns: 1fr; gap: 40px; }
    .welcome-images img { height: 300px; }
    .welcome-desc { font-size: 16px; }
    .img-col:first-child { display: none; }
  }
</style>
