---
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const reviews = [
  {
    name: 'Sophie M.',
    date: '2025-02-15',
    text: locale === 'nl' ? 'Dita is een uitstekende coloriste! Ze heeft mijn haar getransformeerd. Ik ben heel tevreden met het resultaat.' : locale === 'en' ? 'Dita is an excellent colorist! She transformed my hair. I am very satisfied with the result.' : 'Dita est une excellente coloriste ! Elle a transformé mes cheveux. Je suis très satisfaite du résultat.',
    rating: 5,
  },
  {
    name: 'Marco L.',
    date: '2025-01-20',
    text: locale === 'nl' ? 'Grazi is een geweldige stylist, zeer professioneel en attent. De sfeer is warm en uitnodigend.' : locale === 'en' ? 'Grazi is a great stylist, very professional and attentive. The atmosphere is warm and welcoming.' : 'Grazi est un super styliste, très professionnel et attentionné. L\'ambiance est chaleureuse et accueillante.',
    rating: 5,
  },
  {
    name: 'Laura D.',
    date: '2025-03-01',
    text: locale === 'nl' ? 'Al jaren klant, altijd tevreden. Het team is gepassioneerd en luistert echt naar wat je wilt.' : locale === 'en' ? 'Been a client for years, always satisfied. The team is passionate and truly listens to what you want.' : 'Cliente depuis des années, toujours satisfaite. L\'équipe est passionnée et à l\'écoute de ce que vous voulez.',
    rating: 5,
  },
];

const testimonialsLabel = locale === 'nl' ? 'Getuigenissen van klanten' : locale === 'en' ? 'Client Testimonials' : 'Témoignages de clients';
---

<section class="section testimonials-section">
  <div class="container">
    <p class="testi-label">{testimonialsLabel}</p>
    <h2 class="section-title">{i.testimonials.sectionTitle}</h2>
    <div class="google-badge">
      <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#4285F4" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#34A853" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#EA4335" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
      <span class="google-rating">4.5</span>
      <div class="google-stars">&#9733;&#9733;&#9733;&#9733;&#9734;</div>
      <span class="google-count">({i.testimonials.reviewCount})</span>
    </div>
    <div class="reviews-grid">
      {reviews.map((review) => (
        <div class="review-card">
          <div class="review-header">
            <div class="review-avatar">{review.name[0]}</div>
            <div>
              <p class="review-name">{review.name}</p>
              <div class="review-stars">
                {Array.from({ length: review.rating }).map(() => (
                  <span class="star">&#9733;</span>
                ))}
              </div>
            </div>
          </div>
          <p class="review-text">{review.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testi-label {
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-brown);
    margin-bottom: 0.8rem;
  }

  .google-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .google-rating {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-black);
  }

  .google-stars {
    color: #f5a623;
    font-size: 18px;
  }

  .google-count {
    color: var(--color-text);
    font-size: 14px;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .review-card {
    background: var(--color-white);
    border: 1px solid #eee;
    padding: 2rem;
    border-radius: 8px;
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-brown);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 16px;
  }

  .review-name {
    font-weight: 600;
    font-size: 14px;
    color: var(--color-black);
  }

  .star {
    color: #f5a623;
    font-size: 14px;
  }

  .review-text {
    color: var(--color-text);
    font-size: 14px;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }
</style>
