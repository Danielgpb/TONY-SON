---
interface Props { locale?: string; }
const { locale = 'fr' } = Astro.props;

const reviews = [
  { name: "Léa Tripputi", initial: "L", color: "#5C6BC0", date: "4 jours", text: "Super accueil, j'ai fait une coloration, Soin, Coupe et brushing pour franchement pas cher Pour le travail donné. Je reviendrai, merci encore" },
  { name: "Julia Sara Kolodko", initial: "J", color: "#E53935", date: "1 sem.", text: "Merci beaucoup! Mon balayage est juste incroyable je recommande vivement à bientôt" },
  { name: "Maria Paz Rejala", initial: "M", color: "#43A047", date: "2 sem.", text: "Un grand merci pour l'accueil chaleureux au salon! Tammy est une excellente professionnelle, n'hésitez pas à prendre rdv avec elle. Ella habla español y es muy amable" },
  { name: "Anissa Bekkouri", initial: "A", color: "#7B1FA2", date: "2 sem.", text: "Superbe expérience avec Grazi! À refaire !" },
  { name: "Norah Meme", initial: "N", color: "#43A047", date: "2 sem.", text: "Super salon : excellent service et une coiffure impeccable. Grazy est aux petits soins" },
  { name: "Sarah CHEVIOT", initial: "S", color: "#E53935", date: "5 sem.", text: "Première expérience au salon, ravi de cette nouvelle coupe, Grazia m'a fait un résultat incroyable tout en respectant mes attentes ! Je recommande" },
  { name: "Ewelina Marek", initial: "E", color: "#1E88E5", date: "5 sem.", text: "J'ai vécu une expérience incroyable chez ce coiffeur à Bruxelles. Toujours très agréables, ils mettent un sourire sur mon visage à chaque visite. Leurs conseils sont toujours pertinents. Surtout un graaand merci à Grazy et Salvatore !" },
  { name: "Anahita K.", initial: "A", color: "#E53935", date: "5 sem.", text: "Grazi a fait un blond incroyable sur mes cheveux. J'ai fait beaucoup de coiffeur et c'est vraiment la couleur la plus réussie." },
  { name: "FoodieChef", initial: "F", color: "#1565C0", date: "5 sem.", text: "Adorable! L'ambiance est chouette et je serai ravie d'y aller me couper les cheveux très bientôt!" },
  { name: "Mariane C. Dos Santos", initial: "M", color: "#6A1B9A", date: "6 sem.", text: "Excellent service with outstanding professionals, I highly recommend them!!" },
  { name: "Helen Dos Santos", initial: "H", color: "#00897B", date: "6 sem.", text: "Great service and great professionals, I recommend it to everyone who lives nearby!" },
  { name: "Beatryz Galvão", initial: "B", color: "#D81B60", date: "6 sem.", text: "The best!! without a doubt my favorite." },
  { name: "Beatriz Muniz", initial: "B", color: "#FB8C00", date: "6 sem.", text: "Impeccable service, quality products, I was very satisfied." },
  { name: "Luisa Almeida", initial: "L", color: "#7B1FA2", date: "6 sem.", text: "Lovely place, great service!! ❤️" },
  { name: "Giacomo Mallaci", initial: "G", color: "#455A64", date: "6 sem.", text: "Très bon coiffeur, voir l'un des meilleurs sur Bruxelles. Patron et personnel au top je recommande!" },
];

const googleMapsUrl = "https://search.google.com/local/reviews?placeid=ChIJH4YBhhjDw0cR05o_ZDBl-Vc";
---

<section class="google-reviews">
  <div class="container">
    <!-- Header -->
    <div class="gr-header">
      <div class="gr-header-left">
        <svg class="gr-google-logo" viewBox="0 0 24 24" width="28" height="28">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div>
          <div class="gr-title">Avis Google</div>
          <div class="gr-rating">
            <span class="gr-score">4,5</span>
            <span class="gr-stars">★★★★<span class="gr-star-half">★</span></span>
            <span class="gr-count">342 avis</span>
          </div>
        </div>
      </div>
      <a href={googleMapsUrl} target="_blank" rel="noopener" class="gr-write-btn">Écrire un avis</a>
    </div>

    <!-- Carousel -->
    <div class="gr-carousel">
      {reviews.map(r => (
        <div class="gr-card">
          <div class="gr-card-header">
            <div class="gr-avatar" style={`background:${r.color}`}>{r.initial}</div>
            <div>
              <div class="gr-name">{r.name}</div>
              <div class="gr-date">{r.date}</div>
            </div>
          </div>
          <div class="gr-card-stars">★★★★★</div>
          <p class="gr-text">{r.text}</p>
        </div>
      ))}
    </div>

    <!-- Footer link -->
    <div class="gr-footer">
      <a href={googleMapsUrl} target="_blank" rel="noopener">Voir tous les avis sur Google &rarr;</a>
    </div>
  </div>
</section>

<style>
  .google-reviews {
    padding: 30px 0;
    background: var(--color-cream);
  }

  .gr-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
    flex-wrap: wrap;
    gap: 10px;
  }
  .gr-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .gr-google-logo { flex-shrink: 0; }
  .gr-title {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-heading);
    text-transform: none;
  }
  .gr-rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 2px;
  }
  .gr-score {
    font-weight: 700;
    font-size: 16px;
    color: var(--color-heading);
  }
  .gr-stars {
    color: #FBBC05;
    font-size: 16px;
    letter-spacing: 1px;
  }
  .gr-star-half {
    background: linear-gradient(90deg, #FBBC05 50%, #dadce0 50%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .gr-count {
    font-size: 13px;
    color: var(--color-text-light);
  }
  .gr-write-btn {
    font-family: var(--font-accent);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 10px 20px;
    border: 1px solid var(--color-border);
    color: var(--color-heading);
    transition: var(--transition);
  }
  .gr-write-btn:hover {
    background: var(--color-heading);
    color: var(--color-white);
  }

  /* Carousel */
  .gr-carousel {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 10px;
    scrollbar-width: thin;
    scrollbar-color: var(--color-gold) transparent;
  }
  .gr-carousel::-webkit-scrollbar { height: 6px; }
  .gr-carousel::-webkit-scrollbar-track { background: transparent; }
  .gr-carousel::-webkit-scrollbar-thumb { background: var(--color-gold); border-radius: 3px; }

  .gr-card {
    min-width: 300px;
    max-width: 320px;
    flex-shrink: 0;
    scroll-snap-align: start;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .gr-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .gr-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
    font-size: 17px;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    background-image: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, rgba(0,0,0,0.1) 100%);
    background-blend-mode: overlay;
  }
  .gr-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-heading);
  }
  .gr-date {
    font-size: 12px;
    color: var(--color-text-light);
  }
  .gr-card-stars {
    color: #FBBC05;
    font-size: 14px;
    letter-spacing: 2px;
  }
  .gr-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .gr-footer {
    text-align: center;
    margin-top: 15px;
  }
  .gr-footer a {
    font-family: var(--font-accent);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-gold-text);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
  }
  .gr-footer a:hover {
    color: var(--color-heading);
  }

  @media (max-width: 768px) {
    .gr-card { min-width: 260px; max-width: 280px; }
    .gr-header { flex-direction: column; align-items: flex-start; }
  }
</style>
