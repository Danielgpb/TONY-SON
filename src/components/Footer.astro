---
import type { Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const col1Title = locale === 'nl' ? 'Afspraak maken' : locale === 'en' ? 'Book an appointment' : 'Prendre rendez-vous';
const col2Title = locale === 'nl' ? 'Openingstijden' : locale === 'en' ? 'Opening hours' : "Horaire d'ouverture";
const tueFri = locale === 'nl' ? 'Dinsdag - Vrijdag' : locale === 'en' ? 'Tuesday - Friday' : 'Mardi - Vendredi';
const sat = locale === 'nl' ? 'Zaterdag' : locale === 'en' ? 'Saturday' : 'Samedi';
const sunMon = locale === 'nl' ? 'Dimanche - Lundi' : locale === 'en' ? 'Sunday - Monday' : 'Dimanche - Lundi';
const closed = locale === 'nl' ? 'Gesloten' : locale === 'en' ? 'Closed' : 'Fermé';
const taglineText = locale === 'nl' ? "Tony&Son De elegantie en stijl, doorgegeven van generatie op generatie." : locale === 'en' ? "Tony&Son Elegance and style, passed down from generation to generation." : "Tony&Son L'élégance et le style, transmis de génération en génération.";
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <h4>{col1Title}</h4>
        <p class="footer-address">Rue Bonneels 27, 1210 Saint-Josse-ten-Noode, Belgique</p>
        <h3 class="footer-phone">+32 2 230 55 37</h3>
        <p><a href="mailto:infotonyson@gmail.com" class="footer-email">infotonyson@gmail.com</a></p>
        <div class="footer-social">
          <a href="https://www.facebook.com/tonysoncoiffure/?locale=fr_FR" target="_blank" rel="noopener" aria-label="Facebook">
            <span class="social-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </span>
          </a>
          <a href="https://www.instagram.com/tonysonhairstylist" target="_blank" rel="noopener" aria-label="Instagram">
            <span class="social-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </span>
          </a>
          <a href="https://www.tiktok.com/@tonysonhairdresser" target="_blank" rel="noopener" aria-label="TikTok">
            <span class="social-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.73a8.19 8.19 0 004.76 1.52v-3.4a4.85 4.85 0 01-1-.16z"/></svg>
            </span>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h4>{col2Title}</h4>
        <p class="footer-hours">{tueFri}: 09:00 - 19:00</p>
        <p class="footer-hours">{sat}: 09:00 - 18:00</p>
        <p class="footer-hours">{sunMon}: {closed}</p>
      </div>

      <div class="footer-col">
        <p class="footer-tagline">{taglineText}</p>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Tony&Son. All rights reserved.</p>
    </div>
  </div>
</footer>

<a href="#" class="back-to-top" id="back-to-top">&uarr;</a>

<style>
  .footer {
    background: var(--color-black-alt);
    color: var(--color-white);
    padding: 80px 0 0;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
  }
  .footer-col h4 {
    font-family: var(--font-accent);
    font-size: 18px;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: var(--color-white);
  }
  .footer-col p,
  .footer-hours {
    font-size: 15px;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  .footer-address {
    margin-bottom: 1rem;
  }
  .footer-phone {
    color: var(--color-gold) !important;
    font-size: 22px;
    font-weight: 400;
    text-transform: none;
    margin-bottom: 0.5rem;
  }
  .footer-email {
    color: var(--color-gold);
    transition: var(--transition);
  }
  .footer-email:hover {
    opacity: 0.7;
  }
  .footer-social {
    display: flex;
    gap: 0;
    margin-top: 1.5rem;
  }
  .social-icon {
    color: var(--color-gold);
    font-size: 24px;
    margin-right: 15px;
    transition: var(--transition);
  }
  .social-icon:hover {
    opacity: 0.7;
  }
  .footer-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: var(--color-text-light);
    line-height: 1.7;
  }
  .footer-bottom {
    margin-top: 60px;
    padding: 25px 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .footer-bottom p {
    font-size: 14px;
    color: var(--color-text-light);
  }

  .back-to-top {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 45px;
    height: 45px;
    background: var(--color-gold);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    z-index: 999;
    opacity: 0;
    transition: opacity 0.3s, background-color 0.3s;
  }
  .back-to-top:hover {
    background: var(--color-black-alt);
  }
  .back-to-top.visible { opacity: 1; }

  @media (max-width: 768px) {
    .footer { padding: 60px 0 0; }
    .footer-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>

<script>
  const btn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) btn?.classList.add('visible');
    else btn?.classList.remove('visible');
  });
  btn?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
