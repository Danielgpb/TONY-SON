---
import type { Locale } from '../i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const images = [
  '/images/IMG_9729.jpg', '/images/IMG_9725.jpg',
  '/images/IMG_6355.jpg', '/images/IMG_6358.jpg',
  '/images/IMG_6356.jpg', '/images/IMG_6359.jpg',
  '/images/IMG_9724.jpg', '/images/IMG_9726.jpg',
];
---

<section class="gallery-section">
  <div class="gallery-grid">
    {images.map((src) => (
      <div class="gallery-item">
        <img src={src} alt="Tony&Son" loading="lazy" />
        <div class="gallery-overlay">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </div>
      </div>
    ))}
  </div>
  <div class="gallery-float">
    <h3>@instagram</h3>
    <p>Follow us on Instagram<br/><a href="https://www.instagram.com/tonysonhairstylist" target="_blank" rel="noopener">@tonysonhairstylist</a></p>
  </div>
</section>

<style>
  .gallery-section {
    position: relative;
    margin-top: 150px;
    margin-bottom: -1px;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .gallery-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
    cursor: pointer;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 3.5s cubic-bezier(.17, .05, .13, .85);
  }
  .gallery-item:hover img {
    transform: scale(1.05);
  }
  .gallery-overlay {
    position: absolute;
    inset: 20px;
    background: rgba(209, 176, 150, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-float {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-black-alt);
    padding: 60px 70px;
    z-index: 10;
    text-align: center;
    min-width: 320px;
  }
  .gallery-float h3 {
    color: var(--color-white);
    font-family: var(--font-heading);
    font-size: 28px;
    margin-bottom: 12px;
    text-transform: none;
  }
  .gallery-float p {
    color: var(--color-text-light);
    font-size: 18px;
    line-height: 1.6;
  }
  .gallery-float a {
    color: var(--color-gold);
  }
  .gallery-float a:hover {
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .gallery-float { padding: 40px 50px; min-width: auto; }
  }
  @media (max-width: 768px) {
    .gallery-section { margin-top: 80px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-float {
      position: relative;
      top: 0;
      left: 0;
      transform: none;
      width: 100%;
      padding: 40px 20px;
    }
    .gallery-float h3 { font-size: 22px; }
    .gallery-float p { font-size: 16px; }
  }
</style>
